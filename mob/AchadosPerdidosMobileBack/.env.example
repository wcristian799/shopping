PORT=3000
JWT_SECRET=troque-essa-chave

DB_HOST=seu-host-do-banco
DB_PORT=3306
DB_NAME=achados_perdidos_iguatemi
DB_USER=seu-usuario
DB_PASSWORD=sua-senha

IMAGENS_PATH=/var/app/imagens

# Opcional: use se o banco em nuvem exigir certificado CA
# DB_CA=-----BEGIN CERTIFICATE-----...-----END CERTIFICATE-----

# Necessario para gerar o PDF identico ao desktop no servidor
# Aponte para a copia do projeto Java e das classes compiladas no ambiente de deploy
DESKTOP_PROJECT_ROOT=/var/app/Achados-e-Perdidos-Iguatemi
DESKTOP_JAVA_CLASSES_DIR=/var/app/tools/java-out
DESKTOP_MYSQL_CONNECTOR=/var/app/mysql-connector-j-8.4.0.jar
